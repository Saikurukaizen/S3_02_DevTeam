<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalle de Tarea - Gestor de Tareas</title>
    <link rel="stylesheet" href="<?= asset('stylesheets/layout.css') ?>">
</head>
<body>
    <?php
    // Obtiene la tarea que viene del controller (usando el getter mágico del framework)
    $task = $this->task;
    // Verifica si la tarea existe y tiene id, si no muestra error y termina
    if (!isset($task) || !$task || !is_array($task) || empty($task['id'])) {
        // Si no hay tarea, muestra mensaje de error y sale
        echo '<div class="detalle-tarea"><h1>No se encontró la tarea solicitada</h1></div>';
        return;
    }
    ?>
    
    <div class="create-task-page">
        <div class="create-task-container">
            <h1>Detalle de Tarea</h1>
            
            <form class="create-task-form">
                <div class="form-group">
                    <label for="titulo">Título</label>
                    <input type="text" id="titulo" name="titulo" 
                           value="<?= htmlspecialchars($task['titulo']) ?>" 
                           readonly style="background-color: #f8f9fa; cursor: not-allowed;">
                </div>
                
                <div class="form-group">
                    <label for="descripcion">Descripción</label>
                    <textarea name="descripcion" id="descripcion" 
                              readonly style="background-color: #f8f9fa; cursor: not-allowed; resize: none;" rows="4"><?= htmlspecialchars($task['descripcion']) ?></textarea>
                </div>
                
                <div class="form-group">
                    <label for="estado">Estado</label>
                    <select name="estado" id="estado" disabled style="background-color: #f8f9fa; cursor: not-allowed;">
                        <option value="pendiente" <?= $task['estado'] === 'pendiente' ? 'selected' : '' ?>>Pendiente</option>
                        <option value="en_proceso" <?= $task['estado'] === 'en_proceso' ? 'selected' : '' ?>>En Proceso</option>
                        <option value="hecho" <?= $task['estado'] === 'hecho' ? 'selected' : '' ?>>Completado</option>
                    </select>
                </div>
                
                <div class="form-actions">
                    <a href="<?= url('task/update') ?>?id=<?= htmlspecialchars($task['id']) ?>" class="btn-create">
                        Editar Tarea
                    </a>
                    <button type="button" class="btn-cancel delete-btn" 
                            onclick="confirmarEliminacion(<?= htmlspecialchars($task['id']) ?>)">
                        Excluir Tarea
                    </button>
                    <a href="<?= url('') ?>" class="btn-cancel">
                        Volver
                    </a>
                </div>
            </form>
        </div>
    </div>
    
    <script>
        function confirmarEliminacion(taskId) {
            // Crear un modal personalizado en lugar del confirm() del navegador
            const modal = document.createElement('div');
            modal.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-color: rgba(0,0,0,0.5);
                display: flex;
                align-items: center;
                justify-content: center;
                z-index: 10000;
            `;
            
            const modalContent = document.createElement('div');
            modalContent.style.cssText = `
                background-color: white;
                padding: 2rem;
                border-radius: 8px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.3);
                max-width: 400px;
                width: 90%;
                text-align: center;
            `;
            
            modalContent.innerHTML = `
                <h3 style="margin-bottom: 1rem; color: #172b4d; font-size: 1.2rem;">Confirmar Eliminación</h3>
                <p style="margin-bottom: 2rem; color: #6c757d; line-height: 1.5;">¿Estás seguro de que quieres eliminar esta tarea? Esta acción no se puede deshacer.</p>
                <div style="display: flex; gap: 1rem; justify-content: center;">
                    <button onclick="deleteTask(${taskId}); this.closest('.modal').remove();" 
                            style="background-color: #dc3545; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.9rem; min-width: 100px; transition: all 0.2s ease;">
                        Sí, Eliminar
                    </button>
                    <button onclick="this.closest('.modal').remove()" 
                            style="background-color: #6c757d; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 6px; cursor: pointer; font-weight: 600; font-size: 0.9rem; min-width: 100px; transition: all 0.2s ease;">
                        Cancelar
                    </button>
                </div>
            `;
            
            modal.className = 'modal';
            modal.appendChild(modalContent);
            document.body.appendChild(modal);
        }
        
        function deleteTask(taskId) {
            // Crear un formulario temporal para hacer POST
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '<?= url('task/delete') ?>';
            
            // Agregar el campo ID
            const idInput = document.createElement('input');
            idInput.type = 'hidden';
            idInput.name = 'id';
            idInput.value = taskId;
            
            form.appendChild(idInput);
            document.body.appendChild(form);
            form.submit();
        }
    </script>
</body>
</html>
 
