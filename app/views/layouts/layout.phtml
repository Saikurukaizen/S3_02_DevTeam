<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Gestor de Tareas</title>
	<link rel="stylesheet" href="/fullstackphp-sprint3/S302/S3_02_DevTeam/web/stylesheets/layout.css">
</head>
<body>

    <!-- Sidebar lateral izquierda -->
    <div class="sidebar">
        <button onclick="location.href='/fullstackphp-sprint3/S302/S3_02_DevTeam/web/task/create'">
            + Nueva Tarea
        </button>

        <!-- Icono de papelera para Drop futuro -->
        <div id="trash" class="trash" ondrop="dropUpdate(event, 'delete')" ondragover="allowDrop(event)">
            🗑 Papelera
        </div>
    </div>

    <!-- Área principal del tablero -->
    <div class="main">
        <!-- Mensajes flash para feedback al usuario -->
        <?php if($flashSuccess = $_SESSION['flash']['success'] ?? null): ?>
            <div id="flash-message" class="success"><?=htmlspecialchars($flashSuccess)?></div>
            <?php unset($_SESSION['flash']['success']); ?>
        <?php endif; ?>
        <?php if($flashError = $_SESSION['flash']['error'] ?? null): ?>
            <div id="flash-message" class="error"><?=htmlspecialchars($flashError)?></div>
            <?php unset($_SESSION['flash']['error']); ?>
        <?php endif; ?>

        <h1>Lista de Tareas</h1>

        <!-- Contenedor del tablero estilo Trello -->
        <div class="board" style="display: flex; gap: 1rem;">

            <!-- Columna: Pendiente -->
            <div id="pendiente" ondrop="dropUpdate(event, 'pendiente')" ondragover="allowDrop(event)">
                <h2>Pendiente</h2>
                <!-- Aqui se inyectan las tareas del estado 'pendiente' desde read.phtml -->
                <!-- Cada tarjeta debe ser draggable y clickeable para ver detalles -->
            </div>

            <!-- Columna: En Proceso -->
            <div id="en_proceso" ondrop="dropUpdate(event, 'en_proceso')" ondragover="allowDrop(event)">
                <h2>En Proceso</h2>
                <!-- Aqui se inyectan las tareas del estado 'en_proceso' -->
                <!-- Cada tarjeta debe ser draggable y clickeable para ver detalles -->
            </div>

            <!-- Columna: Completado -->
            <div id="hecho" ondrop="dropUpdate(event, 'hecho')" ondragover="allowDrop(event)">
                <h2>Completado</h2>
                <!-- Aqui se inyectan las tareas del estado 'hecho' -->
                <!-- Cada tarjeta debe ser draggable y clickeable para ver detalles -->
            </div>

        </div>

        <!-- Aquí se inserta el contenido generado por read.phtml -->
        <?php echo $this->content(); ?>
    </div>

<script src="/javascripts/flash.js"></script>
</body>
</html>
