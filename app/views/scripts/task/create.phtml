<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Crear Nueva Tarea - Gestor de Tareas</title>
    <link rel="stylesheet" href="/stylesheets/layout.css">
</head>
<body>
    <div class="create-task-page">
        <div class="create-task-container">
            <h1>Crear Nueva Tarea</h1>
            
            <form method="post" action="<?= url('task/create') ?>" class="create-task-form">
                <div class="form-group">
                    <label for="titulo">Título *</label>
                    <input type="text" id="titulo" name="titulo" placeholder="Título de la tarea..." maxlength="50" required>
                </div>
                
                <div class="form-group">
                    <label for="descripcion">Descripción</label>
                    <textarea name="descripcion" id="descripcion" placeholder="Añade una descripción detallada..." maxlength="500" rows="4"></textarea>
                </div>
                
                <div class="form-group">
                    <label for="estado">Estado *</label>
                    <select name="estado" id="estado" required>
                        <option value="">Selecciona un estado</option>
                        <option value="pendiente">Pendiente</option>
                        <option value="en_proceso">En Proceso</option>
                        <option value="hecho">Completado</option>
                    </select>
                </div>
                
                <div class="form-actions">
                    <button type="submit" class="btn-create">Crear Tarea</button>
                    <a href="<?= url('') ?>" class="btn-cancel">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</body>
</html>

