<?php
// Este archivo genera los elementos card de las tareas para el tablero principal
// Cada card es draggable y clickeable para ver detalles de la tarea
// Al hacer click, se abre /task/detalle?id=... para ver los detalles
// No se debe mostrar el boton eliminar aqui, solo preview
$i = 1;
foreach ($this->tasks as $task) {
    ?>
    <div class="bg-white p-3 mb-3 rounded shadow-[0_1px_0_rgba(9,30,66,0.25)] 
        cursor-grab transition-transform duration-200 
        hover:-translate-y-0.5 hover:shadow-[0_2px_4px_rgba(9,30,66,0.15)]
        <?php if(empty($task['estado'])) echo 'border-2 border-red-500 bg-[#ffe6e6]'; ?>
        "
        id="<?= htmlspecialchars($task['id']) ?>" 
        data-task-id="<?= htmlspecialchars($task['id']) ?>" 
        data-estado="<?= htmlspecialchars($task['estado']) ?>"
        draggable="true" 
        ondragstart="drag(event)">
        <a href="<?=url('task/detalle')?>?id=<?= htmlspecialchars($task['id']) ?>">
            <strong class="
            block mb-2 text-[#172b4d] text-[0.9rem]
            "><?= htmlspecialchars($task['titulo']) ?></strong>
            <small class="
            block text-[#5e6c84] mb-2 text-[0.8rem] leading-[1.3]
            "><?= htmlspecialchars($task['descripcion']) ?></small>
        </a>
    </div>
    <?php
    $i++;
}
?>
<script src="/web/javascripts/task_organize.js"></script>
