<!-- READ VIEW -->
<!-- Este archivo muestra la lista de tareas que vienen del controlador -->

<h1>Lista de Tareas</h1>

<!-- Iteramos todas las tareas recibidas en $this->tasks -->
<ul>
<?php foreach ($this->tasks as $task): ?>
    <li>
        <!-- Mostramos ID, título, descripción y estado -->
        <strong>ID:</strong> <?= htmlspecialchars($task['id']) ?><br>
