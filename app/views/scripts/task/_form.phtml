<?php
declare(strict_types=1);

$task = $this->task ?? [];
$defaultValues = [
    'titulo' => '',
    'descripcion' => '',
    'estado' => 'pendiente',
    'asignado_a' => ''
];
$task = array_merge($defaultValues, $task);

$action = $this->action ?? '';
$buttonText = $this->buttonText ?? 'Guardar';
$isReadOnly = $this->isReadOnly ?? false;
$showReadActions = $this->showReadActions ?? false;
$showDeleteButton = $this->showDeleteButton ?? false;
?>

<form action="<?= htmlspecialchars($action, ENT_QUOTES, 'UTF-8') ?>" method="POST" class="task-form">
    <?php if (isset($task['id'])): ?>
        <input type="hidden" name="id" value="<?= htmlspecialchars((string)$task['id'], ENT_QUOTES, 'UTF-8') ?>">
    <?php endif; ?>

    <div class="flex flex-col gap-4 w-full max-w-md mx-auto bg-white/10 rounded-xl p-6 shadow-lg">
        <div class="flex flex-col gap-2">
            <label for="titulo" class="font-semibold text-white">Título *</label>
            <input type="text" id="titulo" name="titulo"
                class="px-4 py-2 rounded-lg border border-white/30 bg-white/80 text-gray-900 focus:outline-none focus:ring-2 focus:ring-kanbanBlue"
                value="<?= htmlspecialchars($task['titulo'], ENT_QUOTES, 'UTF-8') ?>"
                <?= $isReadOnly ? 'disabled' : '' ?> required placeholder="Describe tu tarea de manera clara y concisa...">
        </div>
        <div class="flex flex-col gap-2">
            <label for="descripcion" class="font-semibold text-white">Descripción</label>
            <textarea id="descripcion" name="descripcion" rows="4"
                placeholder="Agregar detalles adicionales, instrucciones o notas importantes..."
                class="px-4 py-2 rounded-lg border border-white/30 bg-white/80 text-gray-900 focus:outline-none focus:ring-2 focus:ring-kanbanBlue"
                <?= $isReadOnly ? 'disabled' : '' ?>><?= htmlspecialchars($task['descripcion'], ENT_QUOTES, 'UTF-8') ?></textarea>
        </div>
        <div class="flex flex-col gap-2">
            <label for="asignado_a" class="font-semibold text-white">Asignar a</label>
            <input type="text" id="asignado_a" name="asignado_a"
                value="<?= htmlspecialchars($task['asignado_a'] ?? '', ENT_QUOTES, 'UTF-8') ?>"
                placeholder="Nombre de la persona responsable..."
                class="px-4 py-2 rounded-lg border border-white/30 bg-white/80 text-gray-900 focus:outline-none focus:ring-2 focus:ring-kanbanBlue"
                <?= $isReadOnly ? 'disabled' : '' ?> >
        </div>
        <div class="flex flex-col gap-2">
            <label for="estado" class="font-semibold text-white">Estado</label>
            <select id="estado" name="estado"
                class="px-4 py-2 rounded-lg border border-white/30 bg-white/80 text-gray-900 focus:outline-none focus:ring-2 focus:ring-kanbanBlue"
                <?= $isReadOnly ? 'disabled' : '' ?> >
                <option value="pendiente" <?= $task['estado'] === 'pendiente' ? 'selected' : '' ?>>📋 Pendiente</option>
                <option value="en_progreso" <?= $task['estado'] === 'en_progreso' ? 'selected' : '' ?>>⏳ En Progreso</option>
                <option value="completada" <?= $task['estado'] === 'completada' ? 'selected' : '' ?>>✅ Completada</option>
                <option value="cancelada" <?= $task['estado'] === 'cancelada' ? 'selected' : '' ?>>❌ Cancelada</option>
            </select>
        </div>
        <div class="flex justify-center mt-6">
            <?php if (!$isReadOnly): ?>
                <div class="flex gap-3">
                    <button type="submit" class="px-8 py-2 rounded-lg bg-green-500 text-white font-semibold shadow-md hover:bg-green-600 transition-all duration-200 text-center">
                        <?= htmlspecialchars(str_replace(['✨', '💾'], '', trim($buttonText)), ENT_QUOTES, 'UTF-8') ?>
                    </button>
                    <?php if ($showDeleteButton && isset($task['id'])): ?>
                        <button type="button" class="px-8 py-2 rounded-lg bg-red-500 text-white font-semibold shadow-md hover:bg-red-600 transition-all duration-200 text-center" onclick="confirmarDelete(<?= htmlspecialchars((string)$task['id'], ENT_QUOTES, 'UTF-8') ?>)">
                            Eliminar
                        </button>
                    <?php endif; ?>
                </div>
            <?php endif; ?>
            <?php if ($isReadOnly && ($showReadActions ?? false)): ?>
                <div class="flex gap-3">
                    <a href="<?= Environment::url('task/update?id=' . htmlspecialchars((string)$task['id'], ENT_QUOTES, 'UTF-8')) ?>" class="px-8 py-2 rounded-lg bg-yellow-500 text-white font-semibold shadow-md hover:bg-yellow-600 transition-all duration-200 text-center">
                        Editar Tarea
                    </a>
                    <button type="button" class="px-8 py-2 rounded-lg bg-red-500 text-white font-semibold shadow-md hover:bg-red-600 transition-all duration-200 text-center" onclick="confirmarDelete(<?= htmlspecialchars((string)$task['id'], ENT_QUOTES, 'UTF-8') ?>)">
                        Eliminar
                    </button>
                </div>
            <?php endif; ?>
        </div>
        <?php if (isset($showTip) && $showTip): ?>
            <div class="mt-4 text-yellow-200 text-sm flex items-center gap-2"><span>💡</span> <?= htmlspecialchars($tipText, ENT_QUOTES, 'UTF-8') ?></div>
        <?php endif; ?>
    </div>
</form>