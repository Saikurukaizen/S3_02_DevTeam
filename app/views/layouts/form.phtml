
<!--
    Formulario de tareas
    - Aplica seguridad con htmlspecialchars en todos los valores
    - Usa clases CSS modernas y responsivas
    - Los comentarios explican cada sección
-->
<form method="POST" action="<?= htmlspecialchars($action ?? '', ENT_QUOTES, 'UTF-8') ?>" class="flex flex-col gap-6">
    <!-- Campo: Título de la tarea -->
    <div class="flex flex-col gap-2">
        <label for="titulo" class="font-semibold text-[#172b4d] text-[0.9rem]">Título</label>
        <input type="text" id="titulo" name="titulo"
            value="<?= htmlspecialchars($task['titulo'] ?? '', ENT_QUOTES, 'UTF-8') ?>"
            class="p-3 bg-[#ebecf0] border-none rounded-lg text-[0.8rem] shadow-[0_1px_2px_rgba(0,0,0,0.1)] transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-[#0052cc] <?= !empty($readonly) ? 'bg-[#f8f9fa] cursor-not-allowed' : '' ?>"
            <?= !empty($readonly) ? 'readonly' : '' ?> required>
    </div>

    <!-- Campo: Descripción de la tarea -->
    <div class="flex flex-col gap-2">
        <label for="descripcion" class="font-semibold text-[#172b4d] text-[0.9rem]">Descripción</label>
        <textarea id="descripcion" name="descripcion" rows="4"
            class="p-3 bg-[#ebecf0] border-none rounded-lg text-[0.8rem] shadow-[0_1px_2px_rgba(0,0,0,0.1)] transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-[#0052cc] resize-y min-h-[100px] <?= !empty($readonly) ? 'bg-[#f8f9fa] cursor-not-allowed resize-none' : '' ?>"
            <?= !empty($readonly) ? 'readonly' : '' ?>><?= htmlspecialchars($task['descripcion'] ?? '', ENT_QUOTES, 'UTF-8') ?></textarea>
    </div>

    <!-- Campo: Estado de la tarea -->
    <div class="flex flex-col gap-2">
        <label for="estado" class="font-semibold text-[#172b4d] text-[0.9rem]">Estado</label>
        <select id="estado" name="estado"
            class="p-3 bg-[#ebecf0] border-none rounded-lg text-[0.8rem] shadow-[0_1px_2px_rgba(0,0,0,0.1)] transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-[#0052cc] <?= !empty($readonly) ? 'bg-[#f8f9fa] cursor-not-allowed' : '' ?>"
            <?= !empty($readonly) ? 'disabled' : '' ?>>
            <option value="pendiente" <?= ($task['estado'] ?? '') === 'pendiente' ? 'selected' : '' ?>>Pendiente</option>
            <option value="en_progreso" <?= ($task['estado'] ?? '') === 'en_progreso' ? 'selected' : '' ?>>En Progreso</option>
            <option value="completada" <?= ($task['estado'] ?? '') === 'completada' ? 'selected' : '' ?>>Completada</option>
            <option value="cancelada" <?= ($task['estado'] ?? '') === 'cancelada' ? 'selected' : '' ?>>Cancelada</option>
        </select>
    </div>

    <!-- Botones de acción: Guardar, Eliminar, Cancelar -->
    <div class="flex gap-4 justify-end mt-8 flex-wrap">
        <?php if (empty($readonly)): ?>
            <button type="submit"
                class="bg-[#5aac44] text-white border-none py-3 px-5 rounded-lg cursor-pointer font-semibold text-[0.9rem] transition-all duration-200 shadow-[0_2px_4px_rgba(0,0,0,0.1)] min-w-[100px] text-center inline-block hover:bg-[#519839] hover:-translate-y-0.5 hover:shadow-[0_4px_8px_rgba(0,0,0,0.15)]">
                <?= htmlspecialchars($buttonText ?? 'Guardar', ENT_QUOTES, 'UTF-8') ?>
            </button>
        <?php endif; ?>
        <?php if (!empty($showDelete) && !empty($deleteUrl)): ?>
            <a href="<?= htmlspecialchars(Environment::url($deleteUrl), ENT_QUOTES, 'UTF-8') ?>"
                class="bg-[#dc3545] text-white border-2 border-[#dc3545] py-3 px-5 rounded-lg text-[0.9rem] font-semibold transition-all duration-200 cursor-pointer inline-block text-center min-w-[100px] hover:bg-[#dc3545] hover:text-white hover:border-[#dc3545] hover:shadow-[0_2px_4px_rgba(0,0,0,0.1)]">
                Eliminar
            </a>
        <?php endif; ?>
        <?php if (!empty($cancelUrl)): ?>
            <a href="<?= htmlspecialchars(Environment::url($cancelUrl), ENT_QUOTES, 'UTF-8') ?>"
                class="bg-white text-[#172b4d] border-2 border-[#e1e5e9] py-3 px-5 rounded-lg text-[0.9rem] font-semibold transition-all duration-200 cursor-pointer inline-block text-center min-w-[100px] hover:bg-[#f8f9fa] hover:border-[#c1c7cd] hover:-translate-y-0.5 hover:shadow-[0_2px_4px_rgba(0,0,0,0.1)]">
                Cancelar
            </a>
        <?php endif; ?>
    </div>
</form>

