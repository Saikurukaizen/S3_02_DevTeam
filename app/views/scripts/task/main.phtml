<?php 
if (!isset($estadoColumna)) { $estadoColumna = null; } 
?>
<?php foreach ($this->tasks as $task): ?>
    <?php if ($task['estado'] === $estadoColumna): ?>
        <div class="bg-white p-2 mb-2 rounded shadow-[0_1px_0_rgba(9,30,66,0.25)]
            cursor-grab transition-transform duration-200 text-[0.8rem]
            hover:-translate-y-0.5 hover:shadow-[0_2px_4px_rgba(9,30,66,0.15)]
            <?php if(empty($task['estado'])) echo 'border-2 border-red-500 bg-[#ffe6e6]'; ?>"
            id="<?= htmlspecialchars($task['id']) ?>"
            data-task-id="<?= htmlspecialchars($task['id']) ?>"
            data-estado="<?= htmlspecialchars($task['estado']) ?>"
            draggable="true"
            ondragstart="drag(event)">
            <a href="<?=Environment::url('task/read?id=' . $task['id']) ?>">
                <strong class="block mb-2 text-[#172b4d] text-[0.9rem]">
                    <?= htmlspecialchars($task['titulo']) ?>
                </strong>
                <small class="block text-[#5e6c84] mb-2 text-[0.8rem] leading-[1.3]">
                    <?= htmlspecialchars($task['descripcion']) ?>
                </small>
            </a>
        </div>
    <?php endif; ?>
<?php endforeach; ?>

