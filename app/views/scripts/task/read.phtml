        <strong>Descripcion:</strong> <?= htmlspecialchars($task['descripcion']) ?><br>
        <strong>Estado:</strong> <?= htmlspecialchars($task['estado']) ?><br>

        <!-- Enlace para eliminar esta tarea -->
        <a href="/fullstackphp-sprint3/S302/S3_02_DevTeam/web/task/delete?id=<?= urlencode($task['id']) ?>">
            Eliminar
        </a>

        <hr>
    </li>
<?php endforeach; ?>
