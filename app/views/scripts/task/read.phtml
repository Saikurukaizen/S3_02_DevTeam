<?php
// Este archivo genera los elementos card de las tareas para el tablero principal
// Cada card es draggable y clickeable para ver detalles de la tarea
// Al hacer click, se abre /task/detalle?id=... para ver los detalles
// No se debe mostrar el boton eliminar aqui, solo preview
$i = 1;
foreach ($this->tasks as $task) {
    ?>
    <div 
        id="task-<?= $i ?>" 
        class="task" 
        data-task-id="<?= htmlspecialchars($task['id']) ?>" 
        data-estado="<?= htmlspecialchars($task['estado']) ?>"
        draggable="true" 
        ondragstart="drag(event)"
        onclick="window.location.href='/fullstackphp-sprint3/S302/S3_02_DevTeam/web/task/detalle?id=<?= htmlspecialchars($task['id']) ?>'"
        style="cursor:pointer"
    >
        <!-- Titulo de la tarea -->
        <strong><?= htmlspecialchars($task['titulo']) ?></strong><br>
        <!-- Descripcion de la tarea -->
        <small><?= htmlspecialchars($task['descripcion']) ?></small>
        <!-- No mostrar estado ni botones aqui, solo preview -->
    </div>
    <?php
    $i++;
}
?>
<script>
// Script para mover las tareas a su columna por estado
// Busca todos los elementos con clase task y los coloca en el div correspondiente
// Los ids de columna deben coincidir con los valores de data-estado
window.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.task').forEach(card => {
        const estado = card.getAttribute('data-estado');
        const columna = document.getElementById(estado);
        if (columna) {
            columna.appendChild(card);
        }
    });
});
</script>
