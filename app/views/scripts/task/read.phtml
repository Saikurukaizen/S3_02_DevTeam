<script>
// Função para confirmar exclusão de tarefa
function confirmarDelete(taskId) {
    if (confirm('¿Estás seguro de que quieres eliminar esta tarea?\n\nEsta acción no se puede deshacer.')) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '<?= Environment::url("task/delete") ?>';
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'id';
        input.value = taskId;
        form.appendChild(input);
        document.body.appendChild(form);
        form.submit();
    }
}
</script>
